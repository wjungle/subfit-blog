---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'SubFit 常見問題 FAQ — 100LS 跟讀法、SRT 字幕訓練';
const description = 'SubFit 常見問題：什麼是 100LS 跟讀法、如何匯入 SRT 字幕、支援哪些語言、是否免費等問題解答。';

const faqs = [
	{
		question: 'SubFit 是什麼？',
		answer:
			'SubFit 是免費的英文聽力與口說練習工具，完整實作 100LS 跟讀法與回音法。匯入任何 SRT 字幕檔，就能開始一句一句的聽力與跟讀訓練。',
	},
	{
		question: '什麼是 100LS 跟讀法？',
		answer:
			'100LS 是由「我在 100 天內自學英文翻轉人生」提出的語言學習方法，核心流程是：先純聽（盲聽）→ 看字幕聽 → 跟讀（shadowing）→ 間隔複習。透過反覆接觸同一句子，讓語感自然內化。',
	},
	{
		question: 'SubFit 如何實作 100LS 的跟讀流程？',
		answer:
			'SubFit 把每句字幕拆成獨立訓練單位，依序走過「純聽 → 看聽 → 跟讀錄音 → AI 發音對比 → 間隔重複複習」五個階段，對應 100LS 的完整學習循環。AI 自然發音取代真人錄音，AI 句子講解補充文法與語意。',
	},
	{
		question: '要怎麼開始用 SubFit 練 100LS？',
		answer:
			'直接開啟 https://subfit.app，選擇內建課程或匯入自己的 SRT 字幕檔，點「開始訓練」即可。不需要註冊帳號，完全免費。',
	},
	{
		question: 'SubFit 支援哪些語言？',
		answer:
			'目前主要支援英文，也可以練日文、荷蘭文等有 SRT 字幕的示範課程。AI 講解與翻譯功能以繁體中文為母語設計。',
	},
];

const schema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((faq) => ({
		'@type': 'Question',
		name: faq.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: faq.answer,
		},
	})),
};
---

<html lang="zh-TW">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify(schema)} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0 1em;
			}
			.prose {
				width: 100%;
				max-width: 860px;
				margin: auto;
				padding: 2em 0 3em;
				color: rgb(var(--gray-dark));
			}
			.prose h1 {
				text-align: center;
				margin-bottom: 0.25em;
			}
			.prose .subtitle {
				text-align: center;
				color: rgb(var(--gray));
				font-size: 0.95em;
				margin-bottom: 2em;
			}
			.faq-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 1.25em;
			}
			.faq-item {
				border: 1px solid rgba(var(--gray-light), 0.8);
				border-radius: 10px;
				padding: 1.25em 1.5em;
				background: white;
			}
			.faq-item h2 {
				font-size: 1.05em;
				margin: 0 0 0.6em;
				color: rgb(var(--black));
			}
			.faq-item p {
				margin: 0;
				line-height: 1.75;
				font-size: 0.95em;
			}
			.cta-box {
				margin-top: 3em;
				padding: 1.5em;
				background: linear-gradient(135deg, rgba(99,102,241,0.12), rgba(139,92,246,0.08));
				border: 1px solid rgba(99,102,241,0.25);
				border-radius: 12px;
				text-align: center;
			}
			.cta-box p {
				margin: 0 0 0.75em;
				font-size: 0.95em;
			}
			.cta-box a {
				display: inline-block;
				padding: 0.6em 1.4em;
				background: rgb(99,102,241);
				color: white;
				border-radius: 8px;
				text-decoration: none;
				font-weight: bold;
				font-size: 0.9em;
				transition: background 0.2s;
			}
			.cta-box a:hover {
				background: rgb(79,82,221);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<div class="prose">
				<h1>常見問題 FAQ</h1>
				<p class="subtitle">關於 SubFit 與 100LS 跟讀法的常見疑問</p>
				<ul class="faq-list">
					{faqs.map((faq) => (
						<li class="faq-item">
							<h2>Q：{faq.question}</h2>
							<p>{faq.answer}</p>
						</li>
					))}
				</ul>
				<div class="cta-box">
					<p>準備好開始沉浸式訓練了嗎？</p>
					<a href="https://subfit.app" target="_blank" rel="noopener noreferrer">
						→ 免費試試 SubFit 沉浸式訓練
					</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
