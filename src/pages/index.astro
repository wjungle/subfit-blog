---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-badge">沉浸式英文訓練</div>
				<h1>用「精聽」<br />真正聽懂英文</h1>
				<p class="subtitle">
					大量聽不等於聽懂。SubFit Blog 分享有效的精聽策略、工具評比與學習心法，幫你從「聽到」進化到「聽懂」。
				</p>
				<div class="hero-actions">
					<a href="https://subfit.vercel.app" target="_blank" rel="noopener noreferrer" class="cta-btn primary">
						立即體驗 SubFit App →
					</a>
					<a href="/blog" class="cta-btn secondary">瀏覽文章</a>
				</div>
			</section>

			<section class="features">
				<div class="feature">
					<div class="feature-icon">🎧</div>
					<h2>精聽技巧</h2>
					<p>不只是「多聽」，而是有策略地聽。學習如何用影片字幕做精聽練習，訓練真實語境的聽力。</p>
				</div>
				<div class="feature">
					<div class="feature-icon">🛠️</div>
					<h2>工具評比</h2>
					<p>比較各種沉浸式學習工具的優缺點，找到最適合自己學習節奏的組合。</p>
				</div>
				<div class="feature">
					<div class="feature-icon">🧠</div>
					<h2>學習心法</h2>
					<p>從語言習得研究出發，建立正確的學習觀念，避免常見陷阱，讓時間花在刀口上。</p>
				</div>
			</section>

			{posts.length > 0 && (
				<section class="latest">
					<div class="latest-header">
						<h2>最新文章</h2>
						<a href="/blog" class="see-all">查看全部 →</a>
					</div>
					<div class="post-grid">
						{posts.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-card">
								<div class="post-card-body">
									<p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
									<h3 class="post-title">{post.data.title}</h3>
									<p class="post-desc">{post.data.description}</p>
								</div>
								<span class="post-read">閱讀全文 →</span>
							</a>
						))}
					</div>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 860px;
		margin: 0 auto;
		padding: 0 1.5em 4em;
	}

	/* Hero */
	.hero {
		text-align: center;
		padding: 4em 1em 3em;
	}

	.hero-badge {
		display: inline-block;
		background: rgba(99, 102, 241, 0.12);
		color: rgb(99, 102, 241);
		border: 1px solid rgba(99, 102, 241, 0.3);
		padding: 0.3em 1em;
		border-radius: 999px;
		font-size: 0.85em;
		font-weight: 600;
		margin-bottom: 1.2em;
		letter-spacing: 0.03em;
	}

	.hero h1 {
		font-size: 3em;
		margin-bottom: 0.5em;
		line-height: 1.15;
		background: linear-gradient(135deg, rgb(var(--black)) 40%, rgb(99, 102, 241));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.subtitle {
		font-size: 1.1em;
		color: rgb(var(--gray));
		max-width: 540px;
		margin: 0 auto 2em;
		line-height: 1.7;
	}

	.hero-actions {
		display: flex;
		gap: 1em;
		justify-content: center;
		flex-wrap: wrap;
	}

	.cta-btn {
		display: inline-block;
		padding: 0.75em 1.8em;
		border-radius: 8px;
		text-decoration: none;
		font-weight: bold;
		font-size: 1em;
		transition: all 0.2s;
	}

	.cta-btn.primary {
		background: rgb(99, 102, 241);
		color: white;
	}

	.cta-btn.primary:hover {
		background: rgb(79, 82, 221);
		transform: translateY(-1px);
		box-shadow: 0 4px 16px rgba(99, 102, 241, 0.35);
	}

	.cta-btn.secondary {
		background: transparent;
		color: rgb(var(--gray-dark));
		border: 1.5px solid rgba(var(--gray-light), 1);
	}

	.cta-btn.secondary:hover {
		border-color: rgb(99, 102, 241);
		color: rgb(99, 102, 241);
	}

	/* Features */
	.features {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.5em;
		margin: 1em 0 3.5em;
	}

	.feature {
		padding: 1.5em;
		background: rgba(var(--gray-light), 0.35);
		border-radius: 12px;
		border: 1px solid rgba(var(--gray-light), 1);
		transition: border-color 0.2s;
	}

	.feature:hover {
		border-color: rgba(99, 102, 241, 0.4);
	}

	.feature-icon {
		font-size: 1.8em;
		margin-bottom: 0.5em;
	}

	.feature h2 {
		font-size: 1.05em;
		margin: 0 0 0.5em;
	}

	.feature p {
		font-size: 0.88em;
		color: rgb(var(--gray));
		line-height: 1.65;
		margin: 0;
	}

	/* Latest posts */
	.latest-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1.5em;
	}

	.latest-header h2 {
		margin: 0;
		font-size: 1.5em;
	}

	.see-all {
		color: rgb(99, 102, 241);
		text-decoration: none;
		font-size: 0.9em;
		font-weight: 600;
	}

	.see-all:hover {
		text-decoration: underline;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1.25em;
	}

	.post-card {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: 1.5em;
		border: 1.5px solid rgba(var(--gray-light), 1);
		border-radius: 12px;
		text-decoration: none;
		color: inherit;
		transition: all 0.2s;
		background: white;
	}

	.post-card:hover {
		border-color: rgba(99, 102, 241, 0.5);
		box-shadow: 0 4px 20px rgba(99, 102, 241, 0.1);
		transform: translateY(-2px);
	}

	.post-date {
		font-size: 0.8em;
		color: rgb(var(--gray));
		margin: 0 0 0.5em;
	}

	.post-title {
		font-size: 1em;
		font-weight: 700;
		margin: 0 0 0.6em;
		line-height: 1.4;
		color: rgb(var(--black));
	}

	.post-desc {
		font-size: 0.85em;
		color: rgb(var(--gray));
		line-height: 1.6;
		margin: 0 0 1.2em;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-read {
		font-size: 0.85em;
		color: rgb(99, 102, 241);
		font-weight: 600;
	}
</style>
