---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={`文章列表 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 860px;
				padding: 3em 1.5em;
			}

			.page-title {
				font-size: 2em;
				margin-bottom: 0.25em;
			}

			.page-subtitle {
				color: rgb(var(--gray));
				font-size: 0.95em;
				margin-bottom: 2.5em;
			}

			.post-list {
				display: flex;
				flex-direction: column;
				gap: 1.25em;
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.post-list li a {
				display: flex;
				flex-direction: column;
				padding: 1.5em;
				border: 1.5px solid rgba(var(--gray-light), 1);
				border-radius: 12px;
				text-decoration: none;
				color: inherit;
				background: white;
				transition: all 0.2s;
			}

			.post-list li a:hover {
				border-color: rgba(99, 102, 241, 0.5);
				box-shadow: 0 4px 20px rgba(99, 102, 241, 0.1);
				transform: translateY(-2px);
			}

			.post-date {
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin: 0 0 0.4em;
			}

			.post-title {
				font-size: 1.15em;
				font-weight: 700;
				margin: 0 0 0.5em;
				color: rgb(var(--black));
				line-height: 1.35;
			}

			.post-desc {
				font-size: 0.9em;
				color: rgb(var(--gray));
				line-height: 1.6;
				margin: 0;
			}

			@media (max-width: 720px) {
				main {
					padding: 2em 1em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">所有文章</h1>
			<p class="page-subtitle">共 {posts.length} 篇 · 關於沉浸式英文訓練的技巧與心法</p>
			<ul class="post-list">
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
								<h2 class="post-title">{post.data.title}</h2>
								{post.data.description && (
									<p class="post-desc">{post.data.description}</p>
								)}
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
